# Configuration for the formal equivalent-mutant filter (see EquivHarnessGenerator.cs
# and the equiv_check function in run.sh). These are the Dafny/Z3 knobs expected to
# need tuning; sourced by run.sh.

# Master switch. 0 disables the filter entirely (every alive mutant goes to mutants/alive).
EQUIV_ENABLED=1

# The single proof obligation in every harness is a lemma/function named like this.
EQUIV_FILTER_SYMBOL=EquivCheck__

# Per-assertion wall-clock budget passed to --verification-time-limit (seconds; 0 = none).
# A harness that exceeds this is treated as "not proved equivalent" -> kept alive.
EQUIV_TIME_LIMIT=15

# Deterministic resource budget passed to --resource-limit (Z3 rlimit units).
# 0 = no rlimit (rely on the time limit instead).
EQUIV_RLIMIT=0

# Verifier cores.
EQUIV_CORES=4
